n",5,"~:end-line",1,"~:end-column",21],"~:ns-aliases",["^ ","~$cljs.loader","~$shadow.loader","~$react","~$module$node_modules$react$index"],"~:use-macros",null,"~:excludes",["~#set",[]],"~:name","~$galaticos.routes","~:reader-aliases",["^ "],"~:op","~:ns","~:imports",null,"~:requires",["^ ","~$reitit.frontend","^K","~$rf","^K","~$reitit.frontend.easy","^M","~$rfe","^M","~$cljs.core","^O","~$goog","^P"],"~:seen",["^C",["~:require"]],"~:uses",null,"~:require-macros",["^ ","^O","^O"],"~:form",["~#list",["~$ns","^E","Frontend routing configuration",["^V",["^R",["^K","~:as","^L"],["^M","^X","^N"]]]]],"~:flags",["^ ","^R",["^C",[]]],"~:js-deps",[],"~:deps",["^P","^O","^K","^M"]],"^H","^E","~:resource-id",["~:shadow.build.classpath/resource","galaticos/routes.cljs"],"~:compiled-at",1768849581607,"^F",["^ ","^K","^K","^L","^K","^M","^M","^N","^M","^O","^O","^P","^P"],"~:resource-name","galaticos/routes.cljs","~:warnings",[],"~:source","(ns galaticos.routes\n  \"Frontend routing configuration\"\n  (:require [reitit.frontend :as rf]\n            [reitit.frontend.easy :as rfe]))\n\n(def routes\n  [[\"/login\" {:name :login\n              :title \"Login\"}]\n   [\"/\" {:name :dashboard\n         :title \"Dashboard\"}]\n   [\"/players\" {:name :players\n                :title \"Players\"}]\n   [\"/players/new\" {:name :player-new\n                    :title \"New Player\"}]\n  ;; keep static `/players/new` first; allow broader ids (mongo ObjectId or other)\n  [\"/players/:id/edit\" {:name :player-edit\n                        :title \"Edit Player\"}]\n  [\"/players/:id\" {:name :player-detail\n                   :title \"Player Details\"}]\n   [\"/matches\" {:name :matches\n                :title \"Matches\"}]\n   [\"/matches/new\" {:name :match-new\n                    :title \"New Match\"}]\n   [\"/championships\" {:name :championships\n                      :title \"Championships\"}]\n   [\"/championships/:id\" {:name :championship-detail\n                          :title \"Championship Details\"}]])\n\n(defn- send-log!\n  \"Lightweight debug logger that posts to the ingest endpoint.\"\n  [payload]\n  ;; #region agent log\n  (-> (js/fetch \"http://127.0.0.1:7242/ingest/1c0f55b4-e5fd-4147-be12-c0c768e9871a\"\n                (clj->js {:method \"POST\"\n                          :headers {\"Content-Type\" \"application/json\"}\n                          :body (.stringify js/JSON (clj->js payload))}))\n      (.catch (fn [_] nil)))\n  ;; #endregion\n  )\n\n(def router\n  (let [_ (send-log! {:sessionId \"debug-session\"\n                      :runId \"run1\"\n                      :hypothesisId \"H1\"\n                      :location \"galaticos.routes.cljs:router\"\n                      :message \"Building router with routes\"\n                      :data {:paths (map first routes)}\n                      :timestamp (.now js/Date)})]\n    ;; `conflicts` disabled because reitit 0.9 treats `/players/new`\n    ;; and `/players/:id{...}` as conflicting even with regex constraints.\n    ;; Static route still wins at runtime.\n    (rf/router routes {:conflicts nil})))\n\n(defn match-by-path\n  \"Match route by path\"\n  [path]\n  (let [_ (send-log! {:sessionId \"debug-session\"\n                      :runId \"run1\"\n                      :hypothesisId \"H2\"\n                      :location \"galaticos.routes.cljs:match-by-path\"\n                      :message \"Matching path\"\n                      :data {:path path}\n                      :timestamp (.now js/Date)})]\n    (rf/match-by-path router path)))\n\n(defn href\n  \"Generate href for route\"\n  [route-name & params]\n  (apply rfe/href route-name params))\n\n","~:reader-features",["^C",["~:cljs"]],"~:used-var-namespaces",["^C",["^E","^O","^K","~$js","^M"]],"~:cljc",false,"~:source-map-compact",["^ ","mappings",";AAKA,0BAAA,oFAAA,mFAAA,SAAA,2CAAA,qDAAA,qDAAA,sDAAA,wBAAA,mFAAA,IAAA,2CAAA,qDAAA,+DAAA,sDAAA,4BAAA,mFAAA,WAAA,2CAAA,qDAAA,4DAAA,sDAAA,0BAAA,mFAAA,eAAA,2CAAA,qDAAA,iEAAA,sDAAA